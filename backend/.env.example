# Copy to .env and adjust as needed. All are optional; defaults are demo-ready.

# SQLite database file location.
# ILIAD_DATABASE_PATH=./iliad.db

# Seed an empty database automatically on startup.
# ILIAD_AUTO_SEED=true

# Allow the destructive POST /admin/reset endpoint.
# ILIAD_ALLOW_RESET=true

# Log all SQL to stdout (debugging).
# ILIAD_SQL_ECHO=false

# --- Bland AI outbound calling (Placer's phone-call surface) --------------
# API key from https://app.bland.ai — REQUIRED to place real calls. Secret:
# keep it here in .env (git-ignored), never in committed code.
BLAND_API_KEY=

# Optional overrides:
# BLAND_BASE_URL=https://api.bland.ai
# BLAND_VOICE=June
#
# DEMO SAFETY: force every call to this number regardless of who's on record,
# so a demo never rings a real third party. Clear it to dial real numbers.
BLAND_FORCE_NUMBER=+13179939042
#
# Autonomy gate — party types Placer may call WITHOUT medical-team sign-off.
# Comma-separated. Default is SNF only; widening this removes the human check.
# BLAND_AUTONOMOUS_PARTY_TYPES=snf
