# Copy to .env and adjust as needed. All are optional; defaults are demo-ready.

# SQLite database file location.
# EHR_DATABASE_PATH=./ehr.db

# Seed an empty database automatically on startup.
# EHR_AUTO_SEED=true

# Allow the destructive POST /admin/reset endpoint.
# EHR_ALLOW_RESET=true

# Where the provided FHIR seed data lives.
# EHR_SYNTHETIC_DIR=../synthetic-examples

# Log all SQL to stdout (debugging).
# EHR_SQL_ECHO=false
